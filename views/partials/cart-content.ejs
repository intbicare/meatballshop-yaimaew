<% if(typeof sheet === "undefined" || !sheet){ %>
    <div class="cart-title">
        <h2 data-i18n="orderTitle">Order</h2>
    </div>
<% } %>

<div class="order-number-card">
    <span class="order-number-label" data-i18n="orderNumberLabel">Order number</span>
    <div class="order-number-row">
        <strong class="order-number-value">Add item first</strong>
        <button class="copy-order-btn" type="button" onclick="copyOrderNumber()" disabled data-i18n="copyOrder">Copy</button>
    </div>
    <small data-i18n="orderNumberHelp">Show this number after you pay.</small>
    <small class="copy-status" aria-live="polite"></small>
</div>

<div class="cart-items">
    <div class="empty-cart" data-i18n="emptyCart">Your cart is empty</div>
</div>

<div class="total-row">
    <span class="total-label" data-i18n="totalLabel">Total</span>
    <span class="total-value"><span class="total-amount">0</span> <span data-i18n="baht">baht</span></span>
</div>

<div class="qr-area mt-3">
    <img class="qr-image" alt="PromptPay QR code">
</div>

<p class="payment-note" data-i18n="paymentNote">Scan to pay or download the QR code.</p>

<div class="note-box">
    <label class="note-field" for="<%= (typeof sheet !== 'undefined' && sheet) ? 'customerNameSheet' : 'customerNameDesktop' %>">
        <span class="note-label" data-i18n="customerNameLabel">Customer name</span>
        <input
            class="note-input"
            id="<%= (typeof sheet !== 'undefined' && sheet) ? 'customerNameSheet' : 'customerNameDesktop' %>"
            type="text"
            maxlength="100"
            autocomplete="name"
            data-contact-input="customerName"
            data-i18n-placeholder="customerNamePlaceholder"
            placeholder="Your name">
    </label>
    <label class="note-field" for="<%= (typeof sheet !== 'undefined' && sheet) ? 'customerPhoneSheet' : 'customerPhoneDesktop' %>">
        <span class="note-label" data-i18n="customerPhoneLabel">Phone number</span>
        <input
            class="note-input"
            id="<%= (typeof sheet !== 'undefined' && sheet) ? 'customerPhoneSheet' : 'customerPhoneDesktop' %>"
            type="tel"
            inputmode="tel"
            maxlength="40"
            autocomplete="tel"
            data-contact-input="customerPhone"
            data-i18n-placeholder="customerPhonePlaceholder"
            placeholder="Phone number">
    </label>
    <label class="note-field" for="<%= (typeof sheet !== 'undefined' && sheet) ? 'mapLinkSheet' : 'mapLinkDesktop' %>">
        <span class="note-label" data-i18n="mapLinkLabel">Map link</span>
        <input
            class="note-input"
            id="<%= (typeof sheet !== 'undefined' && sheet) ? 'mapLinkSheet' : 'mapLinkDesktop' %>"
            type="url"
            inputmode="url"
            autocomplete="off"
            data-map-link-input
            data-i18n-placeholder="mapLinkPlaceholder"
            placeholder="Paste map link">
    </label>
    <label class="note-field" for="<%= (typeof sheet !== 'undefined' && sheet) ? 'foodNoteSheet' : 'foodNoteDesktop' %>">
        <span class="note-label" data-i18n="foodNoteLabel">Food note</span>
        <textarea
            class="note-input"
            id="<%= (typeof sheet !== 'undefined' && sheet) ? 'foodNoteSheet' : 'foodNoteDesktop' %>"
            rows="3"
            maxlength="500"
            data-note-input="foodNote"
            data-i18n-placeholder="foodNotePlaceholder"
            placeholder="Example: not spicy, extra sauce"></textarea>
    </label>
    <label class="note-field" for="<%= (typeof sheet !== 'undefined' && sheet) ? 'riderNoteSheet' : 'riderNoteDesktop' %>">
        <span class="note-label" data-i18n="riderNoteLabel">Rider note</span>
        <textarea
            class="note-input"
            id="<%= (typeof sheet !== 'undefined' && sheet) ? 'riderNoteSheet' : 'riderNoteDesktop' %>"
            rows="3"
            maxlength="500"
            data-note-input="riderNote"
            data-i18n-placeholder="riderNotePlaceholder"
            placeholder="Example: call when arrived"></textarea>
    </label>
</div>

<div class="location-box">
    <button class="location-btn" type="button" onclick="useCurrentLocation()" data-i18n="useCurrentLocation">Use current location</button>
    <p class="location-help" data-i18n="mapLinkHelp">Optional. Location is used only to estimate distance from the shop.</p>
    <p class="location-status" aria-live="polite"></p>
</div>

<div class="action-stack">
    <button class="primary-action send-order-action" type="button" onclick="prepareOrderForShop()" data-i18n="submitOrder">Send order to shop</button>
</div>

<div class="send-result-panel d-none" aria-live="polite">
    <strong class="send-result-title" data-i18n="sentToShop">Sent to shop</strong>
    <p class="download-status"></p>
    <div class="backup-actions">
        <button class="secondary-action copy-order-text-btn" type="button" onclick="copyOrderText()" data-i18n="copyOrderText">Copy order text</button>
        <a class="secondary-action shop-slip-link" href="#" download data-i18n="downloadSlip">Download shop slip</a>
    </div>
</div>
