<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Quick Sale</title>
<style>
:root{
    --ink:#171412;
    --muted:#716a62;
    --line:#e8e0d7;
    --paper:#fffaf4;
    --green:#16784c;
    --red:#b42318;
}
*{
    box-sizing:border-box;
}
body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
}
.shell{
    width:min(920px,100%);
    margin:0 auto;
    padding:14px;
}
.topbar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    margin-bottom:14px;
}
h1{
    margin:0;
    font-size:1.35rem;
}
.logout{
    border:1px solid #d8c8b9;
    border-radius:999px;
    background:#fff;
    padding:8px 12px;
    font:inherit;
    font-weight:750;
}
.admin-nav{
    display:flex;
    gap:8px;
    align-items:center;
    flex-wrap:wrap;
}
.admin-link{
    min-height:40px;
    display:inline-flex;
    align-items:center;
    border:1px solid #d8c8b9;
    border-radius:999px;
    background:#fff;
    color:var(--ink);
    padding:8px 12px;
    font-weight:750;
    text-decoration:none;
}
.panel{
    padding:14px;
    border:1px solid var(--line);
    border-radius:8px;
    background:#fff;
    box-shadow:0 8px 22px rgba(42,31,20,.08);
    margin-bottom:14px;
}
.amount-input{
    width:100%;
    min-height:72px;
    border:2px solid var(--ink);
    border-radius:8px;
    padding:0 16px;
    font-size:2rem;
    font-weight:900;
    text-align:center;
}
.quick-grid,
.pay-grid,
.summary-grid{
    display:grid;
    gap:8px;
}
.quick-grid{
    grid-template-columns:repeat(4,minmax(0,1fr));
    margin-top:10px;
}
.pay-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
    margin-top:12px;
}
.summary-grid{
    grid-template-columns:repeat(2,minmax(0,1fr));
}
button,
.pay-label{
    min-height:48px;
    border:1px solid #d8c8b9;
    border-radius:8px;
    background:#fff;
    font:inherit;
    font-weight:850;
}
.quick-btn{
    font-size:1.05rem;
}
.pay-label{
    display:grid;
    place-items:center;
}
.pay-label input{
    position:absolute;
    opacity:0;
}
.pay-label:has(input:checked){
    border-color:var(--ink);
    background:var(--ink);
    color:#fff;
}
.add-btn{
    width:100%;
    margin-top:12px;
    border:0;
    background:var(--green);
    color:#fff;
}
.summary-item{
    padding:10px;
    border:1px solid var(--line);
    border-radius:8px;
    background:#fffaf4;
}
.summary-item span{
    display:block;
    color:var(--muted);
    font-size:.82rem;
    font-weight:750;
}
.summary-item strong{
    font-size:1.35rem;
}
.message{
    margin:0 0 12px;
    padding:10px;
    border-radius:8px;
    font-weight:750;
}
.error{
    background:#fff0ee;
    color:var(--red);
}
.success{
    background:#eefbf2;
    color:var(--green);
}
.sale-row{
    display:grid;
    grid-template-columns:minmax(0,1fr) auto;
    gap:10px;
    padding:10px 0;
    border-bottom:1px solid var(--line);
}
.sale-row:last-child{
    border-bottom:0;
}
.sale-main{
    min-width:0;
}
.sale-number{
    font-weight:850;
}
.sale-meta{
    color:var(--muted);
    font-size:.86rem;
}
.cancelled{
    opacity:.58;
}
.cancel-btn{
    align-self:center;
    min-height:40px;
    color:#fff;
    background:var(--red);
    border:0;
    padding:0 12px;
}
@media (min-width:720px){
    .summary-grid{
        grid-template-columns:repeat(6,minmax(0,1fr));
    }
}
</style>
</head>
<body>
<main class="shell">
    <div class="topbar">
        <h1>Quick Sale</h1>
        <div class="admin-nav">
            <a class="admin-link" href="/admin/order-links">Order Links</a>
            <a class="admin-link" href="/admin/orders">Online Orders</a>
            <form method="POST" action="/admin/logout">
                <button class="logout" type="submit">Logout</button>
            </form>
        </div>
    </div>

    <% if(error){ %>
        <p class="message error"><%= error %></p>
    <% } %>
    <% if(success){ %>
        <p class="message success"><%= success %></p>
    <% } %>

    <section class="panel">
        <form method="POST" action="/admin/quick-sale">
            <input class="amount-input" id="amount" name="amount" type="number" min="1" step="1" inputmode="numeric" placeholder="0" required>

            <div class="quick-grid">
                <% [20,30,40,50,60,80,100].forEach((amount)=>{ %>
                    <button class="quick-btn" type="button" data-amount="<%= amount %>">฿<%= amount %></button>
                <% }) %>
            </div>

            <div class="pay-grid">
                <label class="pay-label">
                    <input type="radio" name="paymentMethod" value="qr" checked>
                    QR
                </label>
                <label class="pay-label">
                    <input type="radio" name="paymentMethod" value="cash">
                    Cash
                </label>
            </div>

            <button class="add-btn" type="submit">Add Sale</button>
        </form>
    </section>

    <section class="panel">
        <h2>Today Summary</h2>
        <div class="summary-grid">
            <div class="summary-item"><span>Total sales</span><strong>฿<%= summary.totalSales %></strong></div>
            <div class="summary-item"><span>QR total</span><strong>฿<%= summary.qrTotal %></strong></div>
            <div class="summary-item"><span>Cash total</span><strong>฿<%= summary.cashTotal %></strong></div>
            <div class="summary-item"><span>Orders</span><strong><%= summary.orderCount %></strong></div>
            <div class="summary-item"><span>Cancelled</span><strong>฿<%= summary.cancelledTotal %></strong></div>
            <div class="summary-item"><span>Cancel count</span><strong><%= summary.cancelledCount %></strong></div>
        </div>
    </section>

    <section class="panel">
        <h2>Recent Sales Today</h2>
        <% if(sales.length === 0){ %>
            <p class="sale-meta">No sales yet.</p>
        <% } %>
        <% sales.forEach((sale)=>{ %>
            <div class="sale-row <%= sale.status === 'cancelled' ? 'cancelled' : '' %>">
                <div class="sale-main">
                    <div class="sale-number"><%= sale.orderNumber %> - ฿<%= sale.total %></div>
                    <div class="sale-meta"><%= sale.paymentMethod.toUpperCase() %> | <%= sale.status %> | <%= new Date(sale.createdAt).toLocaleTimeString('th-TH',{hour:'2-digit',minute:'2-digit'}) %></div>
                </div>
                <% if(sale.status !== 'cancelled'){ %>
                    <form method="POST" action="/admin/quick-sale//cancel">
                        <input type="hidden" name="orderNumber" value="<%= sale.orderNumber %>">
                        <button class="cancel-btn" type="submit">Cancel</button>
                    </form>
                <% } %>
            </div>
        <% }) %>
    </section>
</main>

<script>
document.querySelectorAll(".quick-btn").forEach((button) => {
    button.addEventListener("click", () => {
        document.getElementById("amount").value = button.dataset.amount;
    });
});
</script>
</body>
</html>
