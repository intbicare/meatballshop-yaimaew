document.querySelectorAll(".lang-btn").forEach((button) => {
    button.addEventListener("click", () => setLanguage(button.dataset.lang));
});

document.querySelectorAll(".category-chip").forEach((button) => {
    button.addEventListener("click", () => {
        document.getElementById(button.dataset.target)?.scrollIntoView({
            behavior:"smooth",
            block:"start"
        });
    });
});

document.querySelectorAll(".product-card").forEach((card) => {
    card.addEventListener("click", () => {
        addItem(
            card.dataset.productId,
            card.dataset.productName,
            Number(card.dataset.productPrice)
        );
    });
});

document.getElementById("openCartBtn").addEventListener("click", openCartSheet);
document.querySelectorAll("[data-close-sheet]").forEach((item) => {
    item.addEventListener("click", closeCartSheet);
});

document.querySelectorAll("[data-map-link-input]").forEach((input) => {
    input.addEventListener("input", () => {
        customerMapLink = input.value.trim();
        selectedCustomerLocation = null;

        document.querySelectorAll("[data-map-link-input]").forEach((otherInput) => {
            if(otherInput !== input){
                otherInput.value = input.value;
            }
        });

        updateLocationStatus("");
    });
});

document.querySelectorAll("[data-note-input]").forEach((input) => {
    input.addEventListener("input", () => {
        const noteKey = input.dataset.noteInput;
        orderNotes[noteKey] = input.value.trim();

        document.querySelectorAll(`[data-note-input="${noteKey}"]`).forEach((otherInput) => {
            if(otherInput !== input){
                otherInput.value = input.value;
            }
        });
