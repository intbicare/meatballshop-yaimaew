<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>ร้านของทอดชุบเครื่องแกงใต้ (ขนมไทยยายแมว)</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
:root{
    --ink:#171412;
    --muted:#716a62;
    --line:#e8e0d7;
    --paper:#fffaf4;
    --surface:#ffffff;
    --accent:#d73b1f;
    --accent-dark:#a92615;
    --green:#16784c;
    --shadow:0 14px 34px rgba(42,31,20,.12);
}

*{
    box-sizing:border-box;
}

body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
    padding-bottom:112px;
}

button,
input{
    font:inherit;
}

.app-shell{
    width:min(1120px,100%);
    margin:0 auto;
}

.topbar{
    position:sticky;
    top:0;
    z-index:20;
    background:rgba(255,250,244,.96);
    border-bottom:1px solid var(--line);
    backdrop-filter:blur(14px);
}

.topbar-inner{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    padding:14px 16px 10px;
}

.language-toggle{
    display:flex;
    gap:6px;
    flex:0 0 auto;
    padding:3px;
    border:1px solid #dfd0c2;
    border-radius:999px;
    background:#fff;
}

.lang-btn{
    min-width:42px;
    min-height:34px;
    border:0;
    border-radius:999px;
    background:transparent;
    color:var(--muted);
    font-size:.82rem;
    font-weight:850;
}

.lang-btn.active{
    background:var(--ink);
    color:#fff;
}

.brand-title{
    margin:0;
    font-size:1.12rem;
    line-height:1.15;
    font-weight:800;
}

.brand-subtitle{
    margin:2px 0 0;
    color:var(--muted);
    font-size:.78rem;
}

.category-scroll::-webkit-scrollbar{
    display:none;
}

.category-scroll{
    position:sticky;
    top:67px;
    z-index:18;
    display:flex;
    gap:8px;
    overflow-x:auto;
    padding:10px 16px;
    background:rgba(255,250,244,.96);
    border-bottom:1px solid var(--line);
    scrollbar-width:none;
}

.category-chip{
    flex:0 0 auto;
    min-height:38px;
    padding:0 12px;
    border:1px solid #decfc0;
    border-radius:999px;
    background:#fff;
    color:var(--ink);
    font-size:.86rem;
    font-weight:800;
}

.content-grid{
    display:grid;
    gap:18px;
    padding:16px;
}

.menu-section{
    scroll-margin-top:155px;
}

.section-heading{
    display:flex;
    align-items:end;
    justify-content:space-between;
    gap:12px;
    margin:4px 0 10px;
}

.section-heading h2{
    margin:0;
    font-size:1.1rem;
    font-weight:850;
}

.section-count{
    color:var(--muted);
    font-size:.78rem;
    white-space:nowrap;
}

.product-grid{
    display:grid;
    grid-template-columns:repeat(2,minmax(0,1fr));
    gap:10px;
}

.product-card{
    position:relative;
    min-height:100%;
    overflow:hidden;
    border:1px solid var(--line);
    border-radius:8px;
    background:var(--surface);
    box-shadow:0 4px 16px rgba(42,31,20,.07);
    text-align:left;
    padding:0;
    touch-action:manipulation;
}

.product-card:active{
    transform:scale(.985);
}

.product-image-wrap{
    position:relative;
    aspect-ratio:1/1;
    background:#f2e9df;
}

.product-image{
    width:100%;
    height:100%;
    object-fit:cover;
    display:block;
}

.qty-badge{
    position:absolute;
    top:8px;
    right:8px;
    min-width:30px;
    height:30px;
    display:grid;
    place-items:center;
    border-radius:999px;
    background:var(--accent);
    color:#fff;
    font-size:.86rem;
    font-weight:850;
    box-shadow:0 6px 16px rgba(167,38,21,.35);
}

.product-body{
    display:grid;
    gap:8px;
    padding:10px;
}

.product-name{
    min-height:2.62em;
    margin:0;
    font-size:.91rem;
    line-height:1.31;
    font-weight:800;
}

.product-foot{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:8px;
}

.product-price{
    color:var(--accent-dark);
    font-size:1rem;
    font-weight:900;
    white-space:nowrap;
}

.add-dot{
    width:34px;
    height:34px;
    display:grid;
    place-items:center;
    flex:0 0 auto;
    border-radius:999px;
    background:var(--ink);
    color:#fff;
    font-size:1.18rem;
    line-height:1;
    font-weight:800;
}

.cart-panel{
    display:none;
}

.cart-card,
.sheet-panel{
    border:1px solid var(--line);
    border-radius:8px;
    background:#fff;
    box-shadow:var(--shadow);
}

.cart-title{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
    margin-bottom:12px;
}

.cart-title h2{
    margin:0;
    font-size:1.08rem;
    font-weight:850;
}

.cart-items{
    display:grid;
    gap:10px;
}

.order-number-card{
    display:grid;
    gap:2px;
    margin-bottom:14px;
    padding:12px;
    border:1px solid #ead7c5;
    border-radius:8px;
    background:#fff6eb;
}

.order-number-label{
    color:var(--muted);
    font-size:.78rem;
    font-weight:800;
    text-transform:uppercase;
}

.order-number-value{
    font-size:1.52rem;
    line-height:1.1;
    letter-spacing:0;
}

.order-number-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:10px;
}

.copy-order-btn{
    min-height:36px;
    flex:0 0 auto;
    border:1px solid #d9c8b8;
    border-radius:999px;
    background:#fff;
    color:var(--ink);
    padding:0 12px;
    font-size:.82rem;
    font-weight:850;
}

.copy-order-btn:disabled{
    cursor:not-allowed;
    opacity:.45;
}

.order-number-card small,
.payment-note{
    color:var(--muted);
    font-size:.84rem;
}

.copy-status{
    min-height:18px;
}

.empty-cart{
    padding:18px 12px;
    color:var(--muted);
    text-align:center;
    border:1px dashed #d8c8b9;
    border-radius:8px;
    background:#fffaf4;
}

.cart-line{
    display:grid;
    grid-template-columns:minmax(0,1fr) auto;
    gap:12px;
    align-items:center;
}

.cart-line-name{
    font-weight:750;
    line-height:1.25;
}

.cart-line-price{
    color:var(--muted);
    font-size:.82rem;
}

.qty-control{
    display:flex;
    align-items:center;
    gap:8px;
}

.qty-btn{
    width:36px;
    height:36px;
    border:1px solid #d6c8ba;
    border-radius:999px;
    background:#fff;
    color:var(--ink);
    font-size:1.15rem;
    font-weight:850;
    line-height:1;
}

.qty-value{
    min-width:24px;
    text-align:center;
    font-weight:850;
}

.total-row{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    margin-top:14px;
    padding-top:14px;
    border-top:1px solid var(--line);
}

.total-label{
    color:var(--muted);
    font-size:.86rem;
    font-weight:750;
}

.total-value{
    font-size:1.48rem;
    font-weight:900;
}

.action-stack{
    display:grid;
    gap:9px;
    margin-top:14px;
}

.send-result-panel{
    display:grid;
    gap:10px;
    margin-top:14px;
    padding:12px;
    border:1px solid #b8dcc6;
    border-radius:8px;
    background:#eefbf2;
}

.send-result-title{
    color:var(--green);
    font-size:1rem;
    line-height:1.2;
}

.backup-actions{
    display:grid;
    gap:9px;
}

.primary-action,
.secondary-action{
    min-height:48px;
    border:0;
    border-radius:8px;
    font-weight:850;
}

.primary-action{
    background:var(--green);
    color:#fff;
}

.primary-action:disabled,
.primary-action.is-disabled{
    cursor:not-allowed;
    opacity:.55;
    pointer-events:none;
}

.secondary-action{
    background:#efe7de;
    color:var(--ink);
}

.shop-slip-link{
    display:grid;
    place-items:center;
    color:var(--ink);
    text-decoration:none;
}

.qr-area{
    text-align:center;
}

.qr-area img{
    max-width:210px;
    width:100%;
}

.payment-note{
    margin:10px 0 0;
    text-align:center;
}

.location-box{
    display:grid;
    gap:8px;
    margin-top:12px;
    padding:10px;
    border:1px solid var(--line);
    border-radius:8px;
    background:#fffaf4;
}

.note-box{
    display:grid;
    gap:8px;
    margin-top:12px;
}

.note-field{
    display:grid;
    gap:5px;
}

.note-label{
    color:var(--ink);
    font-size:.86rem;
    font-weight:850;
}

.note-input{
    width:100%;
    min-height:72px;
    resize:vertical;
    border:1px solid #d8c8b9;
    border-radius:8px;
    background:#fff;
    color:var(--ink);
    padding:9px 10px;
    font-size:.9rem;
    line-height:1.35;
}

.location-label{
    color:var(--ink);
    font-size:.86rem;
    font-weight:850;
}

.map-link-input{
    width:100%;
    min-height:44px;
    border:1px solid #d8c8b9;
    border-radius:8px;
    background:#fff;
    color:var(--ink);
    padding:0 10px;
    font-size:.9rem;
}

.location-actions{
    display:grid;
    grid-template-columns:1fr;
    gap:8px;
}

.location-btn{
    min-height:44px;
    border:1px solid #d8c8b9;
    border-radius:8px;
    background:#fff;
    color:var(--ink);
    font-weight:850;
}

.location-help,
.location-status{
    min-height:18px;
    margin:0;
    color:var(--muted);
    font-size:.78rem;
    line-height:1.35;
}

@media (min-width:480px){
    .location-actions{
        grid-template-columns:1fr auto;
    }
}

.download-status{
    min-height:20px;
    margin:0;
    color:var(--muted);
    font-size:.84rem;
}

.bottom-cart{
    position:fixed;
    left:0;
    right:0;
    bottom:0;
    z-index:30;
    padding:10px 14px calc(10px + env(safe-area-inset-bottom));
    background:rgba(255,250,244,.94);
    border-top:1px solid var(--line);
    backdrop-filter:blur(14px);
}

.bottom-cart button{
    width:min(720px,100%);
    min-height:58px;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    margin:0 auto;
    border:0;
    border-radius:8px;
    background:var(--ink);
    color:#fff;
    padding:0 16px;
    font-weight:850;
    box-shadow:0 12px 28px rgba(23,20,18,.22);
}

.bottom-meta{
    display:flex;
    align-items:center;
    gap:8px;
}

.bottom-count{
    min-width:30px;
    height:30px;
    display:grid;
    place-items:center;
    border-radius:999px;
    background:var(--accent);
}

.cart-sheet{
    position:fixed;
    inset:0;
    z-index:40;
    display:none;
}

.cart-sheet.is-open{
    display:block;
}

.sheet-backdrop{
    position:absolute;
    inset:0;
    background:rgba(23,20,18,.44);
}

.sheet-panel{
    position:absolute;
    left:0;
    right:0;
    bottom:0;
    max-height:88vh;
    overflow:auto;
    border-radius:16px 16px 0 0;
    padding:16px;
}

.sheet-handle{
    width:42px;
    height:5px;
    border-radius:999px;
    background:#d8c8b9;
    margin:0 auto 14px;
}

.close-sheet{
    width:40px;
    height:40px;
    display:grid;
    place-items:center;
    border:1px solid #d8c8b9;
    border-radius:999px;
    background:#fff;
    color:var(--ink);
    font-weight:900;
}

@media (min-width:720px){
    body{
        padding-bottom:0;
    }

    .topbar-inner{
        padding:18px 22px 12px;
    }

    .brand-title{
        font-size:1.34rem;
    }

    .category-scroll,
    .content-grid{
        padding-left:22px;
        padding-right:22px;
    }

    .category-scroll{
        top:73px;
    }

    .content-grid{
        grid-template-columns:minmax(0,1fr) 340px;
        align-items:start;
    }

    .product-grid{
        grid-template-columns:repeat(3,minmax(0,1fr));
        gap:14px;
    }

    .cart-panel{
        display:block;
        position:sticky;
        top:126px;
    }

    .cart-card{
        padding:16px;
    }

    .bottom-cart,
    .cart-sheet{
        display:none !important;
    }
}
</style>
</head>
<body>
<%
const grouped = {};

products.forEach(product => {
    const category = product.category || "อื่นๆ";

    if(!grouped[category]){
        grouped[category] = [];
    }

    grouped[category].push(product);
});

const sortedCategories = Object.keys(grouped).sort((a,b)=>{
    if(a.includes("โปร")) return -1;
    if(b.includes("โปร")) return 1;
    if(a.includes("ทอด")) return -1;
    if(b.includes("ทอด")) return 1;
    return a.localeCompare(b,"th");
});
%>

<div class="app-shell">
    <header class="topbar">
        <div class="topbar-inner">
            <div>
                <h1 class="brand-title">ร้านของทอดชุบเครื่องแกงใต้ (ขนมไทยยายแมว)</h1>
                <p class="brand-subtitle" data-i18n="subtitle">เลือกเมนู สแกนจ่าย แล้วส่งออเดอร์</p>
            </div>
            <div class="language-toggle" aria-label="Language">
                <button class="lang-btn active" type="button" data-lang="th">TH</button>
                <button class="lang-btn" type="button" data-lang="en">EN</button>
            </div>
        </div>
    </header>

    <nav class="category-scroll" aria-label="Menu categories">
        <% sortedCategories.forEach(category => { %>
            <button class="category-chip" type="button" data-target="cat-<%= category %>"><%= category %></button>
        <% }) %>
    </nav>

    <main class="content-grid">
        <div>
            <% sortedCategories.forEach(category => { %>
                <section class="menu-section" id="cat-<%= category %>">
                    <div class="section-heading">
                        <h2><%= category %></h2>
                        <span class="section-count" data-count="<%= grouped[category].length %>"><%= grouped[category].length %> รายการ</span>
                    </div>

                    <div class="product-grid">
                        <% grouped[category].forEach(product => { %>
                            <button
                                class="product-card"
                                type="button"
                                data-testid="product-card"
                                data-product-id="<%= product.id %>"
                                data-product-name="<%= product.name %>"
                                data-product-price="<%= product.price %>">
                                <div class="product-image-wrap">
                                    <img
                                        src="<%= product.image_url %>"
                                        alt="<%= product.name %>"
                                        class="product-image"
                                        loading="lazy">
                                    <span class="qty-badge d-none" id="badge-<%= product.id %>">0</span>
                                </div>
                                <div class="product-body">
                                    <p class="product-name"><%= product.name %></p>
                                    <div class="product-foot">
                                        <span class="product-price">฿<%= product.price %></span>
                                        <span class="add-dot" aria-hidden="true">+</span>
                                    </div>
                                </div>
                            </button>
                        <% }) %>
                    </div>
                </section>
            <% }) %>
        </div>

        <aside class="cart-panel">
            <div class="cart-card">
                <%- include("partials/cart-content") %>
            </div>
        </aside>
    </main>
</div>

<div class="bottom-cart">
    <button type="button" id="openCartBtn" data-testid="open-cart">
        <span class="bottom-meta">
            <span class="bottom-count" id="mobileCount">0</span>
            <span data-i18n="viewOrder">ดูออเดอร์</span>
        </span>
        <span>฿<span id="mobileTotal">0</span></span>
    </button>
</div>

<div class="cart-sheet" id="cartSheet" aria-hidden="true">
    <div class="sheet-backdrop" data-close-sheet></div>
    <div class="sheet-panel">
        <div class="sheet-handle"></div>
        <div class="cart-title">
            <h2 data-i18n="orderTitle">รายการสั่งซื้อ</h2>
            <button class="close-sheet" type="button" data-close-sheet data-testid="close-cart" aria-label="Close cart">x</button>
        </div>
        <%- include("partials/cart-content", { sheet: true }) %>
    </div>
</div>

