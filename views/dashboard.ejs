});

function addItem(id, name, price){
    const wasEmpty = getItemCount() === 0;

    clearSubmittedOrder();
    ensureOrderNumber();

    if(!cart[id]){
        cart[id] = {
            id,
            name,
            price,
            qty:0
        };
    }

    cart[id].qty += 1;
    renderCart();

    if(wasEmpty && window.innerWidth < 720){
        openCartSheet();
    }
}

function changeQty(id, qty){
    if(!cart[id]){
        return;
    }

    clearSubmittedOrder();
    cart[id].qty += qty;

    if(cart[id].qty <= 0){
        delete cart[id];
    }

    renderCart();
}

function renderCart(){
    const items = Object.values(cart);
    let total = 0;
    let itemCount = 0;

    document.querySelectorAll(".qty-badge").forEach((badge) => {
        badge.classList.add("d-none");
    });

    const html = items.map((item) => {
        total += item.price * item.qty;
        itemCount += item.qty;

        const badge = document.getElementById(`badge-${item.id}`);
        if(badge){
            badge.innerText = item.qty;
            badge.classList.remove("d-none");
        }

        return `
            <div class="cart-line">
                <div>
                    <div class="cart-line-name">${escapeHtml(item.name)}</div>
                    <div class="cart-line-price">฿${formatBaht.format(item.price)}</div>
                </div>
                <div class="qty-control">
                    <button class="qty-btn" type="button" data-testid="decrease-item" onclick="changeQty('${item.id}',-1)">-</button>
                    <span class="qty-value">${item.qty}</span>
                    <button class="qty-btn" type="button" data-testid="increase-item" onclick="changeQty('${item.id}',1)">+</button>
                </div>
            </div>
        `;
    }).join("");

    const cartHtml = html || `<div class="empty-cart">${t("emptyCart")}</div>`;

    document.querySelectorAll(".cart-items").forEach((container) => {
        container.innerHTML = cartHtml;
    });

    document.querySelectorAll(".total-amount").forEach((item) => {
        item.innerText = formatBaht.format(total);
    });

    document.getElementById("mobileTotal").innerText = formatBaht.format(total);
    document.getElementById("mobileCount").innerText = itemCount;

    if(itemCount === 0){
        orderNumber = "";
        lastQrTotal = null;
        document.querySelectorAll(".qr-image").forEach((image) => {
            image.removeAttribute("src");
        });
    }

    document.querySelectorAll(".order-number-value").forEach((item) => {
        item.innerText = orderNumber || t("addItemFirst");
    });

    document.querySelectorAll(".copy-order-btn").forEach((button) => {
        button.disabled = !orderNumber;
    });

    updateCopyStatus("");

    updateQR(total);
    updatePaymentState(total);
    updateDownloadStatus("");
}

function updateQR(total){
    if(total <= 0 || total > maxQrTotal){
        lastQrTotal = null;
        document.querySelectorAll(".qr-image").forEach((image) => {
            image.removeAttribute("src");
        });
        return;
    }

    if(total === lastQrTotal){
        return;
    }

    lastQrTotal = total;

    document.querySelectorAll(".qr-image").forEach((image) => {
        image.src = `/qr/${total}`;
    });
}

function updatePaymentState(total){
    const isMassOrder = total > maxQrTotal;

    document.querySelectorAll(".payment-note").forEach((note) => {
        note.innerText = isMassOrder ? t("massOrderNote") : t("paymentNote");
    });

    document.querySelectorAll(".send-order-action").forEach((button) => {
        if(isMassOrder || total <= 0){
            button.disabled = true;
        }else{
            button.disabled = false;
        }
    });
}

function getOrderGateFromUrl(){
    const params = new URLSearchParams(window.location.search);
    return {
        source: params.get("source") || "",
        token: params.get("t") || ""
    };
}

function clearSubmittedOrder(){
    currentOrderText = "";
    document.querySelectorAll(".send-result-panel").forEach((panel) => {
        panel.classList.add("d-none");
    });
    document.querySelectorAll(".shop-slip-link").forEach((link) => {
        link.href = "#";
        link.removeAttribute("download");
    });
    updateDownloadStatus("");
}

async function prepareOrderForShop(){
    const order = buildOrderPayload();

    if(!order){
        alert(t("addItemAlert"));
        return;
    }

    if(order.total > maxQrTotal){
        updateDownloadStatus(t("massOrderAlert"));
        return;
    }

    currentOrderText = buildOrderText(order);
    const slipImage = await createSlipImage(order);
    const customerLocation = selectedCustomerLocation;

    document.querySelectorAll(".shop-slip-link").forEach((link) => {
        link.href = slipImage;
        link.download = `${order.orderNumber}.png`;
    });

    showSendResultPanel();
    updateDownloadStatus(t("orderPrepared"));

    try{
        const response = await fetch("/api/orders", {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({
                ...order,
                orderText: currentOrderText,
                slipImage,
                customerLocation,
                customerMapLink,
                foodNote: order.foodNote,
                riderNote: order.riderNote,
                orderGate
            })
        });

        if(!response.ok){
            const errorResult = await response.json().catch(() => ({}));
            throw new Error(errorResult.error || "Order notification failed");
        }

        const result = await response.json();
        if(result.orderNumber && result.orderNumber !== orderNumber){
            orderNumber = result.orderNumber;
            renderCart();
        }

        if(result.trackingUrl){
            const locationLines = [];

            if(result.customerLat && result.customerLng){
                locationLines.push(`Customer lat,lng: ${result.customerLat},${result.customerLng}`);
            }

            if(result.customerMapUrl){
                locationLines.push(`Customer map: ${result.customerMapUrl}`);
            }

            currentOrderText = [
                currentOrderText,
                "",
                `Tracking: ${result.trackingUrl}`,
                ...locationLines
            ].join("\n");
        }

        updateDownloadStatus(
            result.discordNotified ?
                t("discordSent") :
                t("discordNotConfigured")
        );
    }catch(error){
        updateDownloadStatus(error.message || t("discordFailed"));
    }
}

function showSendResultPanel(){
    document.querySelectorAll(".send-result-panel").forEach((panel) => {
        panel.classList.remove("d-none");
    });

    const visiblePanel =
        [...document.querySelectorAll(".send-result-panel")]
            .find((panel)=>{
                const rect = panel.getBoundingClientRect();
                return rect.width > 0 && rect.height > 0;
            });

    if(visiblePanel){
        visiblePanel.scrollIntoView({
            behavior: "smooth",
            block: "nearest"
        });
    }
}

async function copyOrderText(){
    if(!currentOrderText){
        return;
    }

    try{
        if(navigator.clipboard && window.isSecureContext){
            await navigator.clipboard.writeText(currentOrderText);
        }else{
            fallbackCopyText(currentOrderText);
        }
    }catch(error){
        fallbackCopyText(currentOrderText);
    }

    updateDownloadStatus(t("copiedOrderText"));
}

function buildOrderPayload(){
    const items = Object.values(cart);

    if(items.length === 0){
        return null;
    }

    ensureOrderNumber();

    const total = items.reduce((sum, item) => {
        return sum + (item.price * item.qty);
    }, 0);

    return {
        orderNumber,
        shopName,
        language: currentLanguage,
        total,
        foodNote: orderNotes.foodNote,
        riderNote: orderNotes.riderNote,
        createdAt: new Date().toISOString(),
        items: items.map((item) => ({
            id: item.id,
            name: item.name,
            price: item.price,
            qty: item.qty,
            lineTotal: item.price * item.qty
        }))
    };
}

function buildOrderText(order){
    const lines = [
        shopName,
        `${t("orderNumberLabel")}: ${order.orderNumber}`,
        `${t("timeLabel")}: ${formatSlipTime(order.createdAt)}`,
        "",
        ...order.items.map((item) => {
            return `${item.name} ${t("qtyPrefix")}${item.qty} - ฿${formatBaht.format(item.lineTotal)}`;
        }),
        "",
        `${t("totalLabel")}: ฿${formatBaht.format(order.total)}`,
        t("paidText")
    ];

    appendNoteLines(lines, order);

    return lines.join("\n");
}

function appendNoteLines(lines, order){
    if(order.foodNote){
        lines.push("", `${t("foodNoteLabel")}: ${order.foodNote}`);
    }

    if(order.riderNote){
        lines.push("", `${t("riderNoteLabel")}: ${order.riderNote}`);
    }
}

async function createSlipImage(order){
    const canvas = document.createElement("canvas");
    canvas.width = 400;
    canvas.height = calculateSlipHeight(order);

    const ctx = canvas.getContext("2d");
    ctx.fillStyle = "#ffffff";
    ctx.fillRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle = "#111111";
    ctx.textBaseline = "top";

    let y = 18;

    ctx.font = "700 18px system-ui, sans-serif";
    y = drawWrappedText(ctx, shopName, 18, y, 364, 22);

    ctx.font = "700 16px system-ui, sans-serif";
    ctx.fillText(t("slipTitle"), 18, y + 8);
    y += 34;

    ctx.font = "800 24px system-ui, sans-serif";
    ctx.fillText(order.orderNumber, 18, y);
    y += 34;

    ctx.font = "400 13px system-ui, sans-serif";
    ctx.fillText(`${t("timeLabel")}: ${formatSlipTime(order.createdAt)}`, 18, y);
    y += 24;

    ctx.fillText(t("paidText"), 18, y);
    y += 28;

    drawLine(ctx, y);
    y += 14;

    ctx.font = "600 14px system-ui, sans-serif";
    order.items.forEach((item) => {
        y = drawWrappedText(ctx, item.name, 18, y, 360, 17);
        ctx.fillText(`${t("qtyPrefix")}${item.qty}`, 18, y);
        ctx.fillText(`฿${formatBaht.format(item.lineTotal)}`, 308, y);
        y += 24;
    });

    y += 2;
    drawLine(ctx, y);
    y += 18;

    ctx.font = "800 24px system-ui, sans-serif";
    ctx.fillText(t("totalSlip"), 18, y);
    ctx.fillText(`฿${formatBaht.format(order.total)}`, 260, y);

    y += 42;

    y = drawSlipNotes(ctx, order, y);

    const qrImage =
        await loadImage(`/qr/${order.total}`);

    if(qrImage){
        const qrSize = 160;
        const qrX =
            Math.floor((canvas.width - qrSize) / 2);

        ctx.drawImage(
            qrImage,
            qrX,
            y,
            qrSize,
            qrSize
        );

        y += qrSize + 10;
    }

    ctx.font = "700 14px system-ui, sans-serif";
    ctx.textAlign = "center";
    ctx.fillText(
        order.orderNumber,
        canvas.width / 2,
        y
    );
    ctx.textAlign = "left";

    return canvas.toDataURL("image/png");
}

function calculateSlipHeight(order){
    const measureCanvas =
        document.createElement("canvas");

    const measureCtx =
        measureCanvas.getContext("2d");

    let height = 18;

    measureCtx.font = "700 18px system-ui, sans-serif";
    height += getWrappedLineCount(measureCtx, shopName, 364) * 22;

    height += 34;
    height += 34;
    height += 24;
    height += 28;
    height += 14;

    measureCtx.font = "600 14px system-ui, sans-serif";
    order.items.forEach((item) => {
        height += getWrappedLineCount(measureCtx, item.name, 360) * 17;
        height += 24;
    });

    height += 2;
    height += 18;
    height += 42;

    measureCtx.font = "600 13px system-ui, sans-serif";
    height += getSlipNoteHeight(measureCtx, order);

    height += 160;
    height += 10;
    height += 28;

    return Math.max(720,height + 24);
}

function getSlipNoteHeight(ctx, order){
    let height = 0;

    if(order.foodNote){
        height += 24;
        height += getWrappedLineCount(ctx, `${t("foodNoteLabel")}: ${order.foodNote}`, 364) * 17;
    }

    if(order.riderNote){
        height += 24;
        height += getWrappedLineCount(ctx, `${t("riderNoteLabel")}: ${order.riderNote}`, 364) * 17;
    }

    return height;
}

function drawSlipNotes(ctx, order, y){
    if(!order.foodNote && !order.riderNote){
        return y;
    }

    ctx.font = "600 13px system-ui, sans-serif";

    if(order.foodNote){
        y = drawWrappedText(ctx, `${t("foodNoteLabel")}: ${order.foodNote}`, 18, y, 364, 17);
        y += 7;
    }

    if(order.riderNote){
        y = drawWrappedText(ctx, `${t("riderNoteLabel")}: ${order.riderNote}`, 18, y, 364, 17);
        y += 7;
    }

    return y + 10;
}

function getWrappedLineCount(ctx, text, maxWidth){
    const words = String(text).split(" ");
    let line = "";
    let count = 0;

    words.forEach((word) => {
        const testLine = line ? `${line} ${word}` : word;
        if(ctx.measureText(testLine).width > maxWidth && line){
            count += 1;
            line = word;
        }else{
            line = testLine;
        }
    });

    if(line){
        count += 1;
    }

    return Math.max(1,count);
}

function loadImage(src){
    return new Promise((resolve) => {
        const image = new Image();
        image.crossOrigin = "anonymous";
        image.onload = () => resolve(image);
        image.onerror = () => resolve(null);
        image.src = src;
    });
}

function drawWrappedText(ctx, text, x, y, maxWidth, lineHeight){
    const words = String(text).split(" ");
    let line = "";

    words.forEach((word) => {
        const testLine = line ? `${line} ${word}` : word;
        if(ctx.measureText(testLine).width > maxWidth && line){
            ctx.fillText(line, x, y);
            line = word;
            y += lineHeight;
        }else{
            line = testLine;
        }
    });

    if(line){
        ctx.fillText(line, x, y);
        y += lineHeight;
    }

    return y;
}

function drawLine(ctx, y){
    ctx.strokeStyle = "#111111";
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(18,y);
    ctx.lineTo(382,y);
    ctx.stroke();
}

function formatSlipTime(value){
    return new Intl.DateTimeFormat(
        currentLanguage === "th" ? "th-TH" : "en-GB",
        {
            timeZone: "Asia/Bangkok",
            dateStyle: "short",
            timeStyle: "short"
        }
    ).format(new Date(value));
}

function ensureOrderNumber(){
    if(orderNumber){
        return orderNumber;
    }

    const parts = getBangkokDateParts(new Date());
    const datePart = [
        parts.year.slice(-2),
        parts.month,
        parts.day
    ].join("");
    const timePart = [
        parts.hour,
        parts.minute
    ].join("");
    const randomPart = Math.floor(100 + Math.random() * 900);

    orderNumber = `WEB-${datePart}-${timePart}-${randomPart}`;
    return orderNumber;
}

function getBangkokDateParts(date){
    const parts = new Intl.DateTimeFormat("en-GB", {
        timeZone: "Asia/Bangkok",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false
    }).formatToParts(date);

    return Object.fromEntries(
        parts
            .filter((part) => part.type !== "literal")
            .map((part) => [part.type, part.value])
    );
}

async function useCurrentLocation(){
    const location = await getCustomerLocationOnce();

    if(location){
        selectedCustomerLocation = location;
        customerMapLink = "";
        document.querySelectorAll("[data-map-link-input]").forEach((input) => {
            input.value = "";
        });
        updateLocationStatus(t("locationSaved"));
    }else{
        updateLocationStatus(t("locationUnavailable"));
    }
}

function getCustomerLocationOnce(){
    if(customerLocationPromise){
        return customerLocationPromise;
    }

    customerLocationPromise = new Promise((resolve) => {
        if(!navigator.geolocation){
            resolve(null);
            return;
        }

        navigator.geolocation.getCurrentPosition(
            (position) => {
                resolve({
                    lat: position.coords.latitude,
                    lng: position.coords.longitude
                });
            },
            () => {
                resolve(null);
            },
            {
                enableHighAccuracy: true,
                timeout: 8000,
                maximumAge: 300000
            }
        );
    });

    return customerLocationPromise;
}

function getItemCount(){
    return Object.values(cart).reduce((sum, item) => {
        return sum + item.qty;
    }, 0);
}

function openCartSheet(){
    const sheet = document.getElementById("cartSheet");
    sheet.classList.add("is-open");
    sheet.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
}

function closeCartSheet(){
    const sheet = document.getElementById("cartSheet");
    sheet.classList.remove("is-open");
    sheet.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
}

async function copyOrderNumber(){
    if(!orderNumber){
        return;
    }

    try{
        if(navigator.clipboard && window.isSecureContext){
            await navigator.clipboard.writeText(orderNumber);
        }else{
            fallbackCopyText(orderNumber);
        }

        updateCopyStatus(t("copiedOrder"));
    }catch(error){
        fallbackCopyText(orderNumber);
        updateCopyStatus(t("copiedOrder"));
    }
}

function fallbackCopyText(value){
    const input = document.createElement("input");
    input.value = value;
    input.setAttribute("readonly", "readonly");
    input.style.position = "fixed";
    input.style.opacity = "0";
    document.body.appendChild(input);
    input.select();
    document.execCommand("copy");
    document.body.removeChild(input);
}

function escapeHtml(value){
    return String(value).replace(/[&<>"']/g, (char) => {
        return {
            "&":"&amp;",
            "<":"&lt;",
            ">":"&gt;",
            '"':"&quot;",
            "'":"&#039;"
        }[char];
    });
}

function setLanguage(language){
    currentLanguage = language;
    document.documentElement.lang = language;

    document.querySelectorAll(".lang-btn").forEach((button) => {
        button.classList.toggle("active", button.dataset.lang === language);
    });

    document.querySelectorAll("[data-i18n]").forEach((item) => {
        item.innerText = t(item.dataset.i18n);
    });

    document.querySelectorAll("[data-i18n-placeholder]").forEach((item) => {
        item.setAttribute("placeholder", t(item.dataset.i18nPlaceholder));
    });

    document.querySelectorAll(".section-count").forEach((item) => {
        item.innerText = `${item.dataset.count} ${t("itemUnit")}`;
    });

    document.querySelectorAll(".order-number-value").forEach((item) => {
        if(!orderNumber){
            item.innerText = t("addItemFirst");
        }
    });

    document.querySelectorAll(".copy-status").forEach((item) => {
        if(item.innerText){
            item.innerText = t("copiedOrder");
        }
    });

    renderCart();
}

function updateDownloadStatus(message){
    document.querySelectorAll(".download-status").forEach((item) => {
        item.innerText = message;
    });
}

function updateLocationStatus(message){
    document.querySelectorAll(".location-status").forEach((item) => {
        item.innerText = message;
    });
}

function updateCopyStatus(message){
    document.querySelectorAll(".copy-status").forEach((item) => {
        item.innerText = message;
    });
}

function t(key){
    return translations[currentLanguage][key] || key;
}

setLanguage("th");
</script>
