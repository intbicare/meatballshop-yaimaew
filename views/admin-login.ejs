<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Admin Login</title>
<style>
body{
    margin:0;
    min-height:100vh;
    display:grid;
    place-items:center;
    background:#f6f2ec;
    color:#171412;
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
}
.login-box{
    width:min(360px,calc(100% - 32px));
    padding:20px;
    border:1px solid #e4d8cb;
    border-radius:8px;
    background:#fff;
    box-shadow:0 14px 34px rgba(42,31,20,.12);
}
h1{
    margin:0 0 16px;
    font-size:1.35rem;
}
label{
    display:block;
    margin-bottom:6px;
    font-weight:750;
}
input{
    width:100%;
    min-height:48px;
    box-sizing:border-box;
    border:1px solid #d8c8b9;
    border-radius:8px;
    padding:0 12px;
    font:inherit;
}
button{
    width:100%;
    min-height:48px;
    margin-top:14px;
    border:0;
    border-radius:8px;
    background:#171412;
    color:#fff;
    font:inherit;
    font-weight:850;
}
.error{
    margin:0 0 12px;
    color:#b42318;
    font-weight:750;
}
</style>
</head>
<body>
<main class="login-box">
    <h1>Quick Sale Admin</h1>
    <% if(error){ %>
        <p class="error"><%= error %></p>
    <% } %>
    <form method="POST" action="/admin/login">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" autocomplete="current-password" autofocus>
        <button type="submit">Login</button>
    </form>
</main>
</body>
</html>
