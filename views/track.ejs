<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Track Order</title>
<style>
:root{
    --ink:#171412;
    --muted:#716a62;
    --line:#e8e0d7;
    --paper:#fffaf4;
    --surface:#ffffff;
    --accent:#d73b1f;
}
*{
    box-sizing:border-box;
}
body{
    margin:0;
    min-height:100vh;
    background:var(--paper);
    color:var(--ink);
    font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;
}
.shell{
    width:min(560px,100%);
    margin:0 auto;
    padding:18px 14px 32px;
}
.brand{
    margin:0 0 14px;
    font-size:1.05rem;
    font-weight:850;
}
.panel{
    border:1px solid var(--line);
    border-radius:8px;
    background:var(--surface);
    box-shadow:0 12px 28px rgba(42,31,20,.1);
    padding:16px;
}
.label{
    display:block;
    color:var(--muted);
    font-size:.82rem;
    font-weight:750;
}
.order-number{
    margin:0 0 10px;
    font-size:1.7rem;
    font-weight:900;
    overflow-wrap:anywhere;
}
.status{
    display:inline-block;
    margin:0 0 16px;
    padding:8px 10px;
    border-radius:8px;
    background:#fff3ed;
    color:var(--accent);
    font-weight:850;
}
.row{
    padding:12px 0;
    border-top:1px solid var(--line);
}
.value{
    margin-top:4px;
    font-size:1rem;
    font-weight:750;
    white-space:pre-wrap;
}
.total{
    font-size:1.45rem;
    font-weight:900;
}
.error{
    margin:0;
    color:#b42318;
    font-weight:800;
}
</style>
</head>
<body>
<main class="shell">
    <h1 class="brand">ร้านของทอดชุบเครื่องแกงใต้ (ขนมไทยยายแมว)</h1>
    <section class="panel">
        <% if(error){ %>
            <p class="error"><%= error %></p>
        <% }else{ %>
            <span class="label">เลขออเดอร์</span>
            <p class="order-number"><%= order.orderNumber %></p>
            <p class="status"><%= order.statusText %></p>

            <div class="row">
                <span class="label">ยอดรวม</span>
                <div class="value total">฿<%= order.total %></div>
            </div>

            <div class="row">
                <span class="label">รายการ</span>
                <div class="value"><%= order.itemsText %></div>
            </div>

            <div class="row">
                <span class="label">สร้างเมื่อ</span>
                <div class="value"><%= formatBangkokDateTime(order.createdAt) %></div>
            </div>

            <div class="row">
                <span class="label">อัปเดตล่าสุด</span>
                <div class="value"><%= formatBangkokDateTime(order.updatedAt) %></div>
            </div>
        <% } %>
    </section>
</main>
</body>
</html>
