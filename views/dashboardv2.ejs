<!DOCTYPE html>

<html lang="th">

<head>

<meta charset="UTF-8">

<meta
 name="viewport"
 content="width=device-width, initial-scale=1">

<title>Meatball POS V2</title>

<link
href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
rel="stylesheet">

<style>

body{
    background:#f5f5f5;
    padding-bottom:80px;
}

.product-card{
    cursor:pointer;
    transition:.15s;
}

.product-card:hover{
    transform:scale(1.02);
}

.product-image{
    height:140px;
    object-fit:cover;
}

.cart-panel{
    position:sticky;
    top:10px;
}

.qty-badge{
    position:absolute;
    top:10px;
    right:10px;
    z-index:10;
}

.category-tabs{
    overflow-x:auto;
    white-space:nowrap;
    margin-bottom:15px;
}

.category-tabs button{
    margin-right:5px;
}

.mobile-cart{
    position:fixed;
    bottom:0;
    left:0;
    right:0;
    background:#212529;
    color:white;
    padding:12px;
    z-index:9999;
}

@media(max-width:991px){

    body{
        padding-bottom:90px;
    }

    .cart-panel{
        position:static;
    }

}

</style>

</head>

<body>

<%

const grouped = {};

products.forEach(product=>{

```
const category =
    product.category || "อื่นๆ";

if(!grouped[category]){

    grouped[category] = [];

}

grouped[category].push(product);
```

});

const categories =
Object.keys(grouped)
.sort((a,b)=>{

```
if(a.includes("โปร")) return -1;
if(b.includes("โปร")) return 1;

if(a.includes("ทอด")) return -1;
if(b.includes("ทอด")) return 1;

return a.localeCompare(
    b,
    "th"
);
```

});

%>

<div class="container-fluid p-3">

<div
class="d-flex justify-content-between align-items-center mb-3">

<h3>
🍢 Meatball POS
</h3>

<a
href="/logout"
class="btn btn-outline-danger">

Logout

</a>

</div>

<div class="row mb-3">

<div class="col">
<button
class="btn btn-success w-100">
Walk-in
</button>
</div>

<div class="col">
<button
class="btn btn-dark w-100">
Grab
</button>
</div>

<div class="col">
<button
class="btn btn-warning w-100">
LineMan
</button>
</div>

<div class="col">
<button
class="btn btn-danger w-100">
Shopee
</button>
</div>

</div>

<div class="category-tabs">

<% categories.forEach(category=>{ %>

<button
class="btn btn-outline-primary"
onclick="scrollToCategory('<%= category %>')">

<%= category %>

</button>

<% }) %>

</div>

<div class="row">

<div class="col-lg-8">
<% categories.forEach(category=>{ %>

    <%= category %>
    
    <% grouped[category].forEach(product=>{ %>
    
    
    
    
    0
    
    
    
    
    <%= product.name %>
    
    <%= product.price %> บาท
    
    <% }) %>
    
    <% }) %>
    
    ยังไม่มีสินค้า
    
    รวม
    
    0
    
    บาท
    
    
    
    
    สร้าง QR PromptPay
    
    
    
    
    Print Preview
    
    
    
    
    SAVE ORDER
    
    
    
    
    🛒
    
    0
    
    รายการ
    
    |
    
    0
    
    บาท
    
    
    
    
    ดูตะกร้า
    
    Print Preview
    
    
    
    
    
    
    
    PRINT

    <script
src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
</script>

<script>

let cart = {};

function scrollToCategory(category){

document
.getElementById(
"cat-" + category
)
.scrollIntoView({
behavior:"smooth"
});

}

function scrollToCart(){

document
.getElementById(
"cartPanel"
)
.scrollIntoView({
behavior:"smooth"
});

}

function addItem(
id,
name,
price
){

if(!cart[id]){

cart[id] = {

id,
name,
price,
qty:0

};

}

cart[id].qty++;

renderCart();

}

function changeQty(
id,
qty
){

cart[id].qty += qty;

if(
cart[id].qty <= 0
){

delete cart[id];

}

renderCart();

}

function renderCart(){

let html = "";

let total = 0;

let itemCount = 0;

document
.querySelectorAll(
".qty-badge"
)
.forEach(
el=>el.classList.add(
"d-none"
)
);

Object
.values(cart)
.forEach(item=>{

itemCount += item.qty;

total +=
item.price *
item.qty;

const badge =
document
.getElementById(
"badge-" +
item.id
);

if(badge){

badge.innerText =
item.qty;

badge.classList.remove(
"d-none"
);

}

html += `

<div
class="d-flex justify-content-between align-items-center mb-2">

<div>

${item.name}

</div>

<div>

<button
class="btn btn-sm btn-danger"
onclick="changeQty('${item.id}',-1)">

-

</button>

<span class="mx-2">

${item.qty}

</span>

<button
class="btn btn-sm btn-success"
onclick="changeQty('${item.id}',1)">

+

</button>

</div>

</div>

`;

});

if(html === ""){

html =
"ยังไม่มีสินค้า";

}

document
.getElementById(
"cartItems"
)
.innerHTML = html;

document
.getElementById(
"total"
)
.innerText = total;

document
.getElementById(
"mobileTotal"
)
.innerText = total;

document
.getElementById(
"mobileCount"
)
.innerText = itemCount;

}

function generateQR(){

const total =
parseFloat(
document
.getElementById(
"total"
)
.innerText
);

if(
!total ||
total <= 0
){

alert(
"ยังไม่มีสินค้า"
);

return;

}

document
.getElementById(
"qrImage"
)
.src =
`https://promptpay.io/0651167368/${total}.png`;

}

function previewPrint(){

let html = "";

Object
.values(cart)
.forEach(item=>{

html += `

<div
class="d-flex justify-content-between">

<div>

${item.name}

</div>

<div>

x${item.qty}

</div>

</div>

`;

});

html += `

<hr>

<h4>

รวม

${document.getElementById("total").innerText}

บาท

</h4>

`;

document
.getElementById(
"printPreviewBody"
)
.innerHTML =
html;

new bootstrap.Modal(
document.getElementById(
"printModal"
)
).show();

}

</script>

</body>

</html>
